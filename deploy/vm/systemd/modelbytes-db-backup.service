[Unit]
Description=Back up the ModelBytes Postgres database
Wants=docker.service
After=docker.service
Requires=docker.service

[Service]
Type=oneshot
User=modelbytes
Group=modelbytes
SupplementaryGroups=docker
EnvironmentFile=/etc/modelbytes/postgres.env
Environment=MODELBYTES_BACKUP_DIR=/var/backups/modelbytes
ExecStart=/opt/modelbytes/deploy/vm/backup-postgres.sh
