# ModelBytes Configuration

# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHANNEL_ID=-100XXXXXXXXXX

# Database (Railway auto-sets this, or use local Postgres)
DATABASE_URL=postgresql://user:pass@localhost:5432/modelbytes

# Fallback summarizer LLM (used by summarize_models when the curator routine
# hasn't supplied a pending/<today>.txt). OpenAI-compatible /chat/completions.
# Prod uses GLM-5.1 via Tenspire (a strong, fast reasoning model). Note: reasoning
# models can return an empty content field if max_tokens is too low — monitor.py
# requests 3000 and falls back to the deterministic template on an empty body.
# MODELBYTES_LLM_URL=https://api.tenspire.ai/v1
# MODELBYTES_LLM_MODEL=glm-5.1:cloud
# MODELBYTES_LLM_KEY=your_key_here

# Slack mirror (optional). When both are set, each published digest is also
# posted to this Slack channel (HTML→mrkdwn). Unset = Telegram-only.
# SLACK_BOT_TOKEN=xoxb-...
# MODELBYTES_SLACK_CHANNEL_ID=C0XXXXXXXXX

# Optional source fetch tuning
# MODELBYTES_HTTP_RETRIES=3
# MODELBYTES_HTTP_BACKOFF_SECONDS=1.0
# MODELBYTES_USER_AGENT=ModelBytes/1.0 (+https://github.com/SovereignSignal/modelbytes)

# ── Ops layer (all optional; alerts print to logs if no destination set) ──
# Private Telegram chat for failure/degradation alerts (DM the bot /start,
# then your chat id). Falls back to the Slack ops channel below.
# MODELBYTES_ADMIN_CHAT_ID=123456789
# MODELBYTES_OPS_SLACK_CHANNEL_ID=C0XXXXXXXXX
# Dead-man's switch (e.g. healthchecks.io check URL): pinged on every run,
# /fail on failures — the external service alerts when pings stop entirely.
# MODELBYTES_HEARTBEAT_URL=https://hc-ping.com/your-uuid
# Grace window for a late curator before the fallback runs (0 disables).
# MODELBYTES_PENDING_GRACE_SECONDS=600
# Required =1 to seed an empty models table (guards against wiped state
# silently skipping every day).
# MODELBYTES_ALLOW_SEED=1
